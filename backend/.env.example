APP_ENV=local
APP_NAME=match-alpha-backend
API_PREFIX=/api/v1
API_INTERNAL_KEY=

DATABASE_URL=postgresql+asyncpg://postgres:<password>@<host>:5432/postgres
DB_CONNECT_TIMEOUT_SECONDS=5
SUPABASE_URL=

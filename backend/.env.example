DEFAULT_TIMEZONE=UTC
GIT_SHA=

FOOTBALL_DATA_TOKEN=
SPORTMONKS_API_TOKEN=
API_FOOTBALL_KEY=
THE_ODDS_API_KEY=
WEATHER_API_KEY=
NEWS_API_KEY=

JOB_MAX_RETRIES=3
HTTP_TIMEOUT_SECONDS=30
ODDS_REFRESH_WINDOW_HOURS=72
WEATHER_CACHE_TTL_MINUTES=120
MIN_CALIBRATION_SAMPLE_SIZE=50
MAX_ECE_FOR_BETTABLE=0.08
